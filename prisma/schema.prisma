// ═══ PAA PROGRAMME D'ACCOMPAGNEMENT À L'AMORÇAGE ═══

model PaaProgram {
  id              String   @id @default(cuid())
  userId          String
  tenantId        String
  status          String   @default("ACTIF") // ACTIF, TERMINE, ABANDONNE, SUSPENDU
  startedAt       DateTime @default(now())
  plannedEndAt    DateTime // J60
  followUpAt      DateTime? // J90 follow-up date
  followUpDone    Boolean  @default(false)
  conclusion      String?  // POURSUITE, DEVELOPPEMENT, CLOTURE_REBOND
  conclusionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  milestones  PaaMilestone[]
  ateliers    PaaAtelierSession[]
  objectives  SmartObjective[]
  satisfactions SatisfactionFeedback[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

model PaaMilestone {
  id          String   @id @default(cuid())
  programId   String
  type        String   // DIAGNOSTIC, SUIVI, CONCLUSION, SUIVI_3MOIS
  label       String
  plannedDate DateTime?
  completedAt DateTime?
  status      String   @default("PLANIFIE") // PLANIFIE, EN_COURS, COMPLETE
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program PaaProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([type])
}

model PaaAtelierSession {
  id          String   @id @default(cuid())
  programId   String
  atelierCode String   // gestion-temps, gestion-crise, cloture-rebond, marche, financier, juridique, etc.
  atelierName String
  completedAt DateTime?
  status      String   @default("NON_SUIVI") // NON_SUIVI, PLANIFIE, COMPLETE
  feedback    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program PaaProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([atelierCode])
}

model SmartObjective {
  id          String   @id @default(cuid())
  programId   String
  title       String
  description String?
  specific    String   // What specifically?
  measurable  String   // How measured?
  achievable  String   // Why achievable?
  relevant    String   // Why relevant?
  timeBound   String   // Deadline
  progress    Int      @default(0) // 0-100
  status      String   @default("EN_COURS") // EN_COURS, ATTEINT, NON_ATTEINT
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program PaaProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model SatisfactionFeedback {
  id          String   @id @default(cuid())
  programId   String
  userId      String
  type        String   // ENTRETIEN, ATELIER, PROGRAMME
  referenceId String?  // entretien ID or atelier session ID
  rating      Int      // 1-5
  comment     String?
  nps         Int?     // 0-10 Net Promoter Score
  createdAt   DateTime @default(now())

  program PaaProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])

  @@index([programId])
  @@index([userId])
  @@index([type])
}
